# Build artifacts
*.o
*.a
*.so
*.dylib
*.res
*.exe
core
gmon.out
*.dSYM/

# Binaries produced by make
mixmaster
mixremailer
mix
mpgp

# Built legacy remailer binary in Src/ (not the Src/remailer/ module tree)
Src/remailer$
test
dllmix
parsedate
tmptst

# Makefile generated by ./Install from Makefile.in
Src/Makefile

# Bison output (parsedate.tab.c is tracked for bison-free builds)
Src/parsedate.tab.h
Src/parsedate.output

# Install / compile scratch
Src/tmptst
Src/tmptst.c
Src/*.tmp

# Mix spool and runtime data (default ~/Mix or compile-time SPOOL)
Mix/
mixrand.bin
*.tmp

# Keys, rings, and secrets — never commit operator/runtime material
secring.*
*.skr
*.pgp
nymdb*
*.pass
*.key

# Operator keyrings outside conf/ (sample rings in conf/ stay tracked)
/pubring.*
!/conf/pubring.asc
!/conf/pubring.mix

/adminkey.txt
!/conf/adminkey.txt

# Local config overrides (keep examples tracked)
conf/mix.cfg
!conf/mix.cfg.ex

# Vendored library trees (when ./Install builds from source)
Src/openssl/
Src/zlib*/
Src/pcre*/
Src/ncurses*/

# Install destination / local bin staging
bin/
dist/
build/

# Runtime logs / stray config at repo root
time.log
/mix.cfg

# Cursor rules — local only, not for GitHub
.cursor/

# Editor and OS noise
*~
.#*
.DS_Store
*.swp
*.swo
.vscode/
.idea/
